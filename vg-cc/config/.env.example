# Copy this file to ~/.claude/.env (user scope)
# or <project>/.claude/.env (project scope) and fill in real values.
# Then: chmod 600 on the target file.

VGE_API_URL=https://api.vigilguard
VGE_API_KEY=vg_live_REPLACE_ME

# Optional
# VGE_TIMEOUT_SECONDS=5
# VGE_WIRE_FORMAT=auto
# VGE_LOG_FILE=/tmp/vge-prompt-logger.log
# VGE_DRY_RUN=0
